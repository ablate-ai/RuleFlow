# 服务器
PORT=8080
ADMIN_PASSWORD=
SURGE_MANAGED_CONFIG_BASE_URL=

# CORS 配置（逗号分隔的允许来源，例如 "https://example.com,https://app.example.com"）
CORS_ALLOWED_ORIGINS=*

# PostgreSQL
DATABASE_URL=postgresql://ruleflow:password@localhost:5432/ruleflow?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# 缓存
CACHE_TTL_SECONDS=3600

# 日志清理配置
LOG_KEEP_DAYS=30
LOG_MAX_RECORDS=10000
LOG_CHECK_INTERVAL=1
